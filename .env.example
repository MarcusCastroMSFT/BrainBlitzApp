# ─── Brain Blitz — Environment Variables ──────────────────────────────────────
# Copy this file to .env and adjust values for your local setup.
# In production (Azure Container Apps), these are set via Bicep + postprovision hook.
#
# Most defaults are already baked into config.ts, so .env is OPTIONAL for local dev.
# Only set values here if you need to override the defaults.

# ── Game Server (server/) ─────────────────────────────────────────────────────

# Port the Express + Socket.io game server listens on
# PORT=3001

# Set to "production" to serve the React SPA from server/dist
# NODE_ENV=development

# ── MCP Server (mcp-server/) ─────────────────────────────────────────────────

# Port the MCP server listens on
# MCP_PORT=3002

# Port of the game server (used by the local reverse proxy)
# GAME_PORT=3001

# Internal URL that the MCP server's reverse proxy forwards Socket.io requests to.
# In Azure this is the game server Container App's FQDN.
# Locally it defaults to http://localhost:<GAME_PORT>.
# GAME_SERVER_PROXY_TARGET=http://localhost:3001

# Public URL widgets use in the browser to connect via Socket.io.
# In Azure this is the MCP Container App's own public FQDN.
# For remote dev, set this to your ngrok/devtunnel URL.
# GAME_SERVER_URL=https://your-tunnel.ngrok-free.app

# Public URL of the React SPA (game server).
# Used to build links for host/edit/play pages.
# In Azure this is the game server Container App's public FQDN.
# APP_BASE_URL=http://localhost:5173

# ── Entra ID Authentication (optional) ───────────────────────────────────────
# Only needed when deploying to Azure with Easy Auth enabled.

# ENTRA_CLIENT_ID=
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_SECRET=
