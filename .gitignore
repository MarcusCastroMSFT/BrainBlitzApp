# Dependencies
node_modules/

# Build outputs
dist/
*.tsbuildinfo

# Environment files (may contain secrets)
.env
.env.local
.env.*.local

# Azure
.azure/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo
*.code-workspace

# SQLite database (generated at runtime)
server/data/*.db
server/data/*.db-journal

# Uploaded images (user content)
server/uploads/*
!server/uploads/.gitkeep

# Built widget HTML (generated by build:widgets)
mcp-server/widgets/*.html
